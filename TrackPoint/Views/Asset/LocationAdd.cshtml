@model TrackPoint.Models.Location;
@{
}

@if(TempData["InputError"] != null)
{
	<div class="alert alert-danger" role="alert">
		@TempData["InputError"]
	</div>
}

<div class="page">
	<div class="card">
		<h1>Register a Location</h1>

		<form>
			<input type="hidden" asp-for="LocationId">
			<div class="section">
                <div>
                    <label asp-for="Name">Name</label>
                    <input type="text" asp-for="Name" value="@Model.Name">
                </div>

                <div>
                    <label asp-for="Abbreviation">Abbreviation</label>
                    <input type="text" asp-for="Abbreviation" value="@Model.Abbreviation">
                </div>

            </div>
			<input type="submit" value="Submit" asp-action="NewLocation" class="primary-btn">
		</form>
	</div>
</div>

