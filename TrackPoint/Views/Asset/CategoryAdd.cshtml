@model TrackPoint.Models.Category;
@{
}
@if(TempData["InputError"] != null)
{
	<div class="alert alert-danger" role="alert">
		@TempData["InputError"]
	</div>
}

<div class="page">
    <div class="card">
        <h1>Register a Category</h1>
        <form>
            <input type="hidden" asp-for="CategoryId">
            <div class="section">
                <div>
                    <label asp-for="Name">Name</label>
                    <input type="text" asp-for="Name" value="@Model.Name">
                </div>

                <div>
                    <label asp-for="Abbreviation">Abbreviation</label>
                    <input type="text" asp-for="Abbreviation" value="@Model.Abbreviation">
                </div>

                <div>
                    <label asp-for="Description">Description</label>
                    <textarea asp-for="Description" placeholder="Description">@Model.Description</textarea>
                </div>

                <div>
                    <label asp-for="DefaultLoanPeriodDays">Default loan period (In days)</label>
                    <input type="number" asp-for="DefaultLoanPeriodDays" value="@Model.DefaultLoanPeriodDays">
                </div>
            </div>

            <div class="section">
                <div class="toggle-row">
                    <label asp-for="ContainsConsumables">This category contains consumables that are not individually tracked</label>
                    <label class="switch">
                        @if (Model.ContainsConsumables)
                        {
                            <input type="checkbox" asp-for="ContainsConsumables" checked>
                            <span class="slider"></span>
                        }
                        else
                        {
                            <input type="checkbox" asp-for="ContainsConsumables">
                            <span class="slider"></span>
                        }
                    </label>
                   
                </div>

                <div class="toggle-row">
                    <label asp-for="RequiresApproval">This category requires approval to check out</label>
                    <label class="switch">
                        @if (Model.RequiresApproval)
                        {
                            <input type="checkbox" asp-for="RequiresApproval" checked>
                            <span class="slider"></span>
                        }
                        else
                        {
                            <input type="checkbox" asp-for="RequiresApproval">
                            <span class="slider"></span>
                        }
                    </label>
                   
                </div>
            </div>
          

            <input type="submit" value="Submit" asp-action="NewCategory" class="primary-btn">
        </form>

    </div>
</div>
